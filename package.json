{
  "name": "serial-terminal-pro",
  "version": "1.0.0",
  "author": "Drai",
  "description": "Terminale seriale con pulsanti programmabili, multi-porta e timestamp UTC",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "postinstall": "electron-rebuild -f -w serialport",
    "rebuild": "electron-rebuild -f -w serialport",
    "build": "electron-builder --win --x64"
  },
  "dependencies": {
    "electron-store": "^8.2.0",
    "serialport": "^12.0.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.6.0",
    "electron": "^28.3.3",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.drai.serial-terminal-pro",
    "productName": "Serial Terminal Pro",
    "win": { "target": "nsis", "icon": "assets/icon.ico" },
    "publish": {
      "provider": "github",
      "owner": "Dammat",
      "repo": "serial-terminal-pro"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
